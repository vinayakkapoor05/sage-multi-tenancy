# Gateway + scheduler (port 8080 by default)
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# vLLM OpenAI-compatible base (no trailing slash), e.g. http://vllm:8000
VLLM_BASE_URL=http://127.0.0.1:8000
VLLM_MODEL=meta-llama/Llama-3.2-1B-Instruct

# Torch worker (BioCLIP)
TORCH_WORKER_URL=http://127.0.0.1:8001

# Batching for torch jobs (ms)
TORCH_BATCH_WINDOW_MS=80
TORCH_MAX_BATCH_SIZE=8
TORCH_ESTIMATED_RUNTIME_MS=120

# WFQ / fairness tuning
WFQ_DECAY_HALF_LIFE_S=30
WFQ_STARVATION_THRESHOLD_S=5
PRIORITY_REALTIME=3
PRIORITY_INTERACTIVE=2
PRIORITY_BATCH=1

# Basic GPU resource layer
MAX_NON_REALTIME_GPU_UTILIZATION_PCT=92
MIN_FREE_VRAM_MB=1024
RESERVE_REALTIME_VRAM_MB=512
MAX_INFLIGHT_VLLM=2
MAX_INFLIGHT_TORCH=2

# Optional: RTSP snapshot fallback for jobs without image_base64.
# Per-job rtsp_url in payload overrides this.
DEFAULT_RTSP_URL=rtsp://130.202.23.153:554/profile1/media.smp
RTSP_SNAPSHOT_TIMEOUT_S=8

# Optional: publish completed/failed job outputs to Waggle.
PYWAGGLE_PUBLISH_ENABLED=false

TORCH_WORKER_HOST=0.0.0.0
TORCH_WORKER_PORT=8001
# cuda or cpu
TORCH_DEVICE=cuda
